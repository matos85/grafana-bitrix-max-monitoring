# ШАБЛОН настроек — этот файл можно хранить в GitHub (без реальных секретов).
# Реальные пароли и ключи Bitrix — только в файле .env (он в .gitignore).
#
# Установка:
#   cp .env.example .env
#   nano .env          # подставьте свои IP, пароли, Client ID/Secret из Bitrix24
#   docker compose --env-file .env up -d --build
#
# См. README.md — «Секреты и чувствительные данные», «Обязательные переменные».
#
# Локальный вход в Grafana (форма логин/пароль):
#   GF_ADMIN_USER / GF_ADMIN_PASSWORD  — администратор
#   GF_VIEWER_USER / GF_VIEWER_PASSWORD — пользователь только просмотр

# --- Адреса ВАШЕГО сервера с Docker (мониторинг) ---
# Замените YOUR_SERVER_IP на IP или домен, как к серверу ходят из браузера/LAN.
# Docker использует GRAFANA_ROOT_URL, OAUTH_BRIDGE_PUBLIC_URL и т.д. — не HOST_IP напрямую.
HOST_IP=YOUR_SERVER_IP

GRAFANA_BIND=0.0.0.0
GRAFANA_PORT=3002
GRAFANA_ROOT_URL=http://YOUR_SERVER_IP:3002/
GRAFANA_DOMAIN=YOUR_SERVER_IP
GF_AUTH_DISABLE_LOGIN_FORM=false

GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_admin_password
GF_VIEWER_USER=viewer
GF_VIEWER_PASSWORD=CHANGE_ME_viewer_password
GF_VIEWER_EMAIL=viewer@local

# OAuth-мост (прокси между Grafana и Bitrix). Публичный URL — для Bitrix Redirect URI.
OAUTH_BRIDGE_BIND=0.0.0.0
OAUTH_BRIDGE_PORT=4181
OAUTH_BRIDGE_PUBLIC_URL=http://YOUR_SERVER_IP:4181
OAUTH_BRIDGE_CLIENT_ID=local.ВАШ_CLIENT_ID
OAUTH_BRIDGE_CLIENT_SECRET=ВАШ_CLIENT_SECRET

# --- Адреса ПОРТАЛА Bitrix24 (у каждой организации свои) ---
# Замените company.bitrix24.ru на домен ВАШЕГО портала (из адресной строки Bitrix).
BITRIX_CLIENT_ID=local.ВАШ_CLIENT_ID
BITRIX_CLIENT_SECRET=ВАШ_CLIENT_SECRET
BITRIX_AUTH_BASE_URL=https://company.bitrix24.ru/oauth/authorize/
# Токен: для облачного Bitrix24 обычно не меняют:
BITRIX_TOKEN_URL=https://oauth.bitrix.info/oauth/token/
BITRIX_REST_BASE=https://company.bitrix24.ru/rest/
# Права: user или user_brief — включить в настройках приложения Bitrix24
BITRIX_OAUTH_SCOPE=user,user_brief,profile,auth

# В кабинете Bitrix24 → приложение → Redirect URI (должен совпасть с .env):
#   ${OAUTH_BRIDGE_PUBLIC_URL}/oauth/callback
# Пример: http://YOUR_SERVER_IP:4181/oauth/callback

# Приём событий MAX-мессенджера (POST JSON)
MAX_METRICS_BIND=0.0.0.0
MAX_METRICS_PORT=9093
# Опционально: если задан — заголовок X-API-Key или Authorization: Bearer
MAX_METRICS_API_KEY=

PROMETHEUS_PUBLIC_BIND=0.0.0.0
PROMETHEUS_PUBLIC_PORT=9092
PROMETHEUS_PUBLIC_URL=http://YOUR_SERVER_IP:9092
# Ровно 32 символа (латиница/цифры). Сгенерируйте свой: openssl rand -hex 16
OAUTH2_PROXY_COOKIE_SECRET=CHANGE_ME_32_CHAR_COOKIE_SECRET1

OAUTH_EMAIL_DOMAIN=local

# MySQL для Grafana (вместо SQLite)
MYSQL_ROOT_PASSWORD=CHANGE_ME_mysql_root
MYSQL_DATABASE=grafana
MYSQL_USER=grafana
MYSQL_PASSWORD=CHANGE_ME_mysql_grafana
